<!-- Announcement icon -->
<div style="text-align:center;margin-bottom:24px;">
  <div style="display:inline-block;width:56px;height:56px;background-color:#e8f5e9;border-radius:50%;line-height:56px;font-size:28px;">📢</div>
</div>

<p style="margin:0 0 8px;font-size:16px;color:#333;">
  Hello <strong><%= @user.display_name %></strong>,
</p>

<p style="margin:0 0 16px;font-size:14px;color:#555;">
  <strong>Announcement Type:</strong> <%= @notification.notification_type.to_s.humanize %><br>
  <strong>Published:</strong> <%= @created_at.in_time_zone('Nairobi').strftime('%B %d, %Y at %I:%M %p') %>
</p>

<h2 style="margin:0 0 16px;font-size:20px;color:#141b2d;font-weight:700;border-bottom:2px solid #4cceac;padding-bottom:10px;">
  <%= @title %>
</h2>

<div style="margin:0 0 24px;font-size:15px;color:#444;line-height:1.7;">
  <%= simple_format(@message, {}, wrapper_tag: 'div', sanitize: false) %>
  <%= @created_at.in_time_zone('Nairobi').strftime('%I:%M %p') %>
</div>

<% if @metadata.present? %>
<div style="margin:0 0 24px;padding:16px;background-color:#eef7f1;border-radius:8px;font-size:14px;color:#444;">
  <strong>Announcement details:</strong>
  <ul style="margin:8px 0 0;padding-left:18px;">
    <% @metadata.each do |key, value| %>
      <li><strong><%= key.to_s.humanize %>:</strong> <%= value %></li>
    <% end %>
  </ul>
</div>
<% end %>

<% if @action_url.present? %>
<p style="margin:0 0 24px;text-align:center;">
  <a href="<%= @action_url %>"
     style="display:inline-block;padding:12px 28px;background-color:#4cceac;color:#141b2d;text-decoration:none;border-radius:6px;font-weight:700;font-size:15px;">
    Read More →
  </a>
</p>
<% end %>

<hr style="border:none;border-top:1px solid #eee;margin:24px 0;">
<p style="margin:0;font-size:13px;color:#888;">
  Stay connected with your community at
  <a href="<%= @frontend_url %>/client/announcements" style="color:#4cceac;">Announcements</a>.
</p>

<p style="margin:16px 0 0;font-size:13px;color:#888;">
  Manage your notification preferences: <a href="<%= @frontend_url %>/client/notifications" style="color:#4cceac;">Notification Settings</a>
</p>
