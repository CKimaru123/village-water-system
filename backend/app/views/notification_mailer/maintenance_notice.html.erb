<!-- Maintenance icon -->
<div style="text-align:center;margin-bottom:24px;">
  <div style="display:inline-block;width:56px;height:56px;background-color:#fff3e0;border-radius:50%;line-height:56px;font-size:28px;">🔧</div>
</div>

<p style="margin:0 0 8px;font-size:16px;color:#333;">
  Hello <strong><%= @user.display_name %></strong>,
</p>

<p style="margin:0 0 16px;font-size:14px;color:#555;">
  <strong>Maintenance type:</strong> <%= @notification.notification_type.to_s.humanize %><br>
  <strong>Sent:</strong> <%= @created_at.strftime('%B %d, %Y at %I:%M %p') %>
</p>

<h2 style="margin:0 0 16px;font-size:20px;color:#141b2d;font-weight:700;border-bottom:2px solid #e05c5c;padding-bottom:10px;">
  <%= @title %>
</h2>

<!-- Maintenance warning banner -->
<div style="background-color:#fff3e0;border-left:4px solid #f0a500;padding:12px 16px;border-radius:4px;margin-bottom:20px;">
  <p style="margin:0;color:#7a4f00;font-size:14px;font-weight:600;">
    ⚠️ Planned Service Notice — please plan accordingly.
  </p>
</div>

<div style="margin:0 0 24px;font-size:15px;color:#444;line-height:1.7;">
  <%= simple_format(@message, {}, wrapper_tag: 'div', sanitize: false) %>
</div>

<% if @metadata.present? %>
<div style="margin:0 0 24px;padding:16px;background-color:#fff7f0;border-radius:8px;font-size:14px;color:#444;">
  <strong>Details:</strong>
  <ul style="margin:8px 0 0;padding-left:18px;">
    <% @metadata.each do |key, value| %>
      <li><strong><%= key.to_s.humanize %>:</strong> <%= value %></li>
    <% end %>
  </ul>
</div>
<% end %>

<% if @action_url.present? %>
<p style="margin:0 0 24px;text-align:center;">
  <a href="<%= @action_url %>"
     style="display:inline-block;padding:12px 28px;background-color:#e05c5c;color:#fff;text-decoration:none;border-radius:6px;font-weight:700;font-size:15px;">
    View Details →
  </a>
</p>
<% end %>

<hr style="border:none;border-top:1px solid #eee;margin:24px 0;">
<p style="margin:0;font-size:13px;color:#888;">
  For urgent issues during maintenance, contact us at
  <a href="mailto:support@village-water.com" style="color:#e05c5c;">support@village-water.com</a>.
</p>

<p style="margin:16px 0 0;font-size:13px;color:#888;">
  Manage your notification preferences: <a href="<%= @frontend_url %>/client/notifications" style="color:#e05c5c;">Notification Settings</a>
</p>
