cat > .gitignore << 'EOF'
# Apply
# Environment files
.env
.env.local
.env.*.local

# Logs
log/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node modules
node_modules/

# Build outputs
build/
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Ruby (if applicable)
Gemfile.lock  # Optional: comment out if using Bundler
.env
EOF